#!/usr/bin/env bash
#
# ch-build-setup-android: prepare the working tree for `flutter build apk|aab`.
#
# An inert, vendor-agnostic helper baked into the chrysalis `flutter` image. It does nothing
# until you invoke it (so non-build jobs pay no cost), reads only CH_BUILD_* environment
# variables (so it assumes no particular CI system), and materializes only the files an Android
# build needs from secrets a CI already holds:
#
#   - dart-defines:    one var per key, CH_BUILD_DEFINE_<KEY>=<value>, written verbatim as
#                      <KEY>=<value> lines into the dart-define file. Pass that file to your
#                      build:  flutter build apk --dart-define-from-file="$CH_BUILD_DART_DEFINE_FILE"
#   - google-services: fetched from Firebase via ch-fetch-firebase-config, from
#                      CH_BUILD_ANDROID_FIREBASE_APP_ID plus the shared
#                      CH_BUILD_FIREBASE_CLIENT_EMAIL / _PRIVATE_KEY, into
#                      android/app/google-services.json
#   - dev signing:     a keystore (generated only when missing) + android/key.properties (written
#                      only when absent), from the CH_BUILD_ANDROID_* knobs in the registry below.
#
# Run it from your Flutter project root. Why these choices (verbatim per-key defines, the
# read-site typing finding, generate-if-absent, the cache var): ../../APPENDIX.md#build-setup-android.
#
# Usage: ch-build-setup-android [--dry-run] [--help]
#
set -euo pipefail

log() { printf 'ch-build-setup-android: %s\n' "$1" >&2; }
die() { printf 'ch-build-setup-android: error: %s\n' "$1" >&2; exit 1; }

# Single source of truth for the defaulted scalar vars: this block feeds both default
# resolution and --help, so the two cannot drift. One per line, NAME|DEFAULT|DESCRIPTION
# ('|' appears in neither field; the DNAME default carries commas but no pipe). The two path
# vars are also baked as image ENVs; the default here is the fallback for running the helper
# outside the image. CH_BUILD_DART_DEFINE_FILE is what you pass to --dart-define-from-file;
# CH_BUILD_CACHE_KEYSTORE is the path to add to your build cache for a stable signing key.
readonly VAR_REGISTRY='
CH_BUILD_ANDROID_KEYSTORE_PASSWORD|storepassword|PKCS12 keystore password (used for both the store and the key)
CH_BUILD_ANDROID_KEY_ALIAS|development|Signing key alias
CH_BUILD_ANDROID_DNAME|CN=Chrysalis Build Setup, O=Chrysalis, C=US|Distinguished name for the generated cert
CH_BUILD_ANDROID_KEY_VALIDITY|10000|Generated cert validity in days
CH_BUILD_ANDROID_KEY_SIZE|2048|Key size in bits
CH_BUILD_ANDROID_KEY_ALG|RSA|Key algorithm
CH_BUILD_DART_DEFINE_FILE|lib/env/dart_defines.env|Output path for --dart-define-from-file (baked image ENV)
CH_BUILD_CACHE_KEYSTORE|android/app/ch-signing.p12|Keystore path; cache it for a stable signing key (baked image ENV)
'

declare -A DEF
while IFS='|' read -r _name _def _; do
  [ -n "$_name" ] && DEF["$_name"]="$_def"
done <<< "$VAR_REGISTRY"

# Value of env var $1 if set and non-empty, else its registry default.
defaulted() { local n="$1"; printf '%s' "${!n:-${DEF[$n]}}"; }

# Write stdin to a file (0600, parents created), or just announce it under --dry-run.
write_file() {
  local path="$1" dry_run="$2"
  if [ "$dry_run" -ne 0 ]; then
    cat >/dev/null
    log "[dry-run] would write $path"
    return 0
  fi
  mkdir -p "$(dirname "$path")"
  cat > "$path"
  chmod 600 "$path"
  log "wrote $path"
}

print_help() {
  cat <<'EOF'
ch-build-setup-android: prepare the working tree for `flutter build apk|aab`.

Reads CH_BUILD_* environment variables and writes only what is set. Run from the Flutter
project root. An existing android/key.properties is never overwritten.

  -n, --dry-run   Show what would be written; write nothing.
  -h, --help      This help.

dart-defines (one variable per key; value written verbatim):
  CH_BUILD_DEFINE_<KEY>=<value>            ->  <KEY>=<value> in the dart-define file
  Then build with:  flutter build apk --dart-define-from-file="$CH_BUILD_DART_DEFINE_FILE"

google-services (fetched from Firebase via ch-fetch-firebase-config --android):
  CH_BUILD_ANDROID_FIREBASE_APP_ID=<1:NN:android:XX>   the Android app to fetch config for
  CH_BUILD_FIREBASE_CLIENT_EMAIL=<sa@proj...>          the service account (needs the
                                                       firebase.clients.get IAM permission)
  CH_BUILD_FIREBASE_PRIVATE_KEY=<pem>                  its private key (escaped \n or real
                                                       newlines both accepted)
  All three set -> android/app/google-services.json.

Variables with defaults (override via the environment):
EOF
  local name def desc
  while IFS='|' read -r name def desc; do
    [ -n "$name" ] || continue
    printf '  %-34s %s [default: %s]\n' "$name" "$desc" "${def:-<store password>}"
  done <<< "$VAR_REGISTRY"
  cat <<'EOF'

Notes:
  - Android signing is set up only when android/key.properties is absent.
  - The keystore is created only when missing; cache CH_BUILD_CACHE_KEYSTORE to keep the
    signing key stable across runs (changing the password invalidates a cached keystore).
  - CH_BUILD_DART_DEFINE_FILE and CH_BUILD_CACHE_KEYSTORE are baked into the image.
EOF
}

# CH_BUILD_DEFINE_<KEY> vars -> verbatim <KEY>=<value> lines in the dart-define file.
setup_dart_defines() {
  local dry_run="$1" file
  file="$(defaulted CH_BUILD_DART_DEFINE_FILE)"
  local -a names=("${!CH_BUILD_DEFINE_@}")
  if [ "${#names[@]}" -eq 0 ]; then
    log "no CH_BUILD_DEFINE_* set; skipping the dart-define file"
    return 0
  fi
  local name key value out=''
  local -a keys=()
  for name in "${names[@]}"; do
    key="${name#CH_BUILD_DEFINE_}"
    value="${!name}"
    case "$value" in
      *$'\n'*) die "$name has a multi-line value; --dart-define-from-file does not support those" ;;
    esac
    out+="$key=$value"$'\n'
    keys+=("$key")
  done
  log "dart-define (${#keys[@]}): ${keys[*]} -> $file"
  printf '%s' "$out" | write_file "$file" "$dry_run"
}

# Fetch android/app/google-services.json from Firebase by delegating to ch-fetch-firebase-config
# --android (the shared fetcher; see APPENDIX.md#build-setup-android). With none of the Firebase
# vars set this does nothing, so a committed google-services.json is left alone; otherwise the
# fetcher validates them and fails fast on a partial set. The credential
# (CH_BUILD_FIREBASE_CLIENT_EMAIL / _PRIVATE_KEY) is project-scoped and shared with the eventual
# iOS setup; only CH_BUILD_ANDROID_FIREBASE_APP_ID is Android-specific.
setup_google_services() {
  local dry_run="$1"
  if [ -z "${CH_BUILD_ANDROID_FIREBASE_APP_ID:-}" ] \
    && [ -z "${CH_BUILD_FIREBASE_CLIENT_EMAIL:-}" ] \
    && [ -z "${CH_BUILD_FIREBASE_PRIVATE_KEY:-}" ]; then
    log "no Firebase vars set; skipping google-services.json"
    return 0
  fi

  # Prefer the copy shipped beside this script; fall back to PATH (both are on PATH in the image).
  local fetcher
  fetcher="$(dirname "${BASH_SOURCE[0]}")/ch-fetch-firebase-config"
  if [ ! -x "$fetcher" ]; then
    command -v ch-fetch-firebase-config >/dev/null 2>&1 \
      || die "ch-fetch-firebase-config not found (it ships alongside this helper in the chrysalis image)"
    fetcher=ch-fetch-firebase-config
  fi

  local -a args=(--android)
  if [ "$dry_run" -ne 0 ]; then args+=(--dry-run); fi
  "$fetcher" "${args[@]}"
}

# Dev signing: keep an existing setup untouched, else generate-if-absent the keystore and
# write key.properties. keytool mints a fresh random key-pair, so caching the keystore (not the
# password) is what keeps the signing key stable across runs.
setup_signing() {
  local dry_run="$1"
  if [ -f android/key.properties ]; then
    log "android/key.properties present; leaving signing untouched"
    return 0
  fi

  local keystore pass key_alias dname validity key_size key_alg
  keystore="$(defaulted CH_BUILD_CACHE_KEYSTORE)"
  pass="$(defaulted CH_BUILD_ANDROID_KEYSTORE_PASSWORD)"
  key_alias="$(defaulted CH_BUILD_ANDROID_KEY_ALIAS)"
  dname="$(defaulted CH_BUILD_ANDROID_DNAME)"
  validity="$(defaulted CH_BUILD_ANDROID_KEY_VALIDITY)"
  key_size="$(defaulted CH_BUILD_ANDROID_KEY_SIZE)"
  key_alg="$(defaulted CH_BUILD_ANDROID_KEY_ALG)"

  if [ -f "$keystore" ]; then
    log "reusing existing keystore $keystore"
  elif [ "$dry_run" -ne 0 ]; then
    log "[dry-run] would generate PKCS12 keystore $keystore (alias $key_alias, $key_alg/$key_size)"
  else
    command -v keytool >/dev/null 2>&1 || die "keytool not found (it ships with the JDK in the chrysalis image)"
    mkdir -p "$(dirname "$keystore")"
    log "generating dev keystore $keystore (alias $key_alias)"
    # PKCS12 is the only supported type (JKS is deprecated). PKCS12 uses one password for the
    # store and the key, so a single CH_BUILD_ANDROID_KEYSTORE_PASSWORD drives both.
    keytool -genkeypair -keystore "$keystore" -storetype PKCS12 \
      -keyalg "$key_alg" -keysize "$key_size" -validity "$validity" \
      -alias "$key_alias" -dname "$dname" \
      -storepass "$pass" -keypass "$pass" >/dev/null
    chmod 600 "$keystore"
  fi

  # key.properties' storeFile resolves relative to android/app/, so the basename is enough.
  write_file android/key.properties "$dry_run" <<PROPS
storePassword=$pass
keyPassword=$pass
keyAlias=$key_alias
storeFile=$(basename "$keystore")
PROPS
}

main() {
  local dry_run=0
  while [ $# -gt 0 ]; do
    case "$1" in
      -n|--dry-run) dry_run=1 ;;
      -h|--help)    print_help; exit 0 ;;
      --)           shift; break ;;
      -*)           die "unknown option: $1 (try --help)" ;;
      *)            die "unexpected argument: $1 (try --help)" ;;
    esac
    shift
  done

  [ -f pubspec.yaml ] || die "no pubspec.yaml in $PWD; run this from your Flutter project root"

  setup_dart_defines "$dry_run"
  setup_google_services "$dry_run"
  setup_signing "$dry_run"

  if [ "$dry_run" -ne 0 ]; then
    log "dry-run complete (nothing written)"
  else
    log "setup complete"
  fi
}

main "$@"
